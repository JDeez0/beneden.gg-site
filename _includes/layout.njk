<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Beneden - A new social platform that never monetizes attention. Truly child-safe, goal-oriented social media for real connection.">
    <title>{% if title %}{{ title }} | {% endif %}Beneden</title>
    <style>
        /* Dark Theme Color System - Following 2025 Best Practices */
        :root {
            /* Background Colors - Avoiding pure black (#000000) */
            --bg-primary: #121212;
            --bg-secondary: #1E1E1E;
            --bg-tertiary: #2A2A2A;

            /* Text Colors - Avoiding pure white (#FFFFFF) */
            --text-primary: #E0E0E0;
            --text-secondary: #BBBBBB;
            --text-tertiary: #888888;

            /* Accent Colors */
            --accent-primary: #8B5CF6;
            --accent-secondary: #A78BFA;
            --accent-hover: #7C3AED;

            /* Semantic Colors */
            --success: #22C55E;
            --warning: #F59E0B;
            --error: #EF4444;

            /* Border Colors */
            --border-light: #2A2A2A;
            --border-medium: #333333;

            /* Typography */
            --font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            --font-size-base: 16px;
            --line-height-relaxed: 1.8;
            --line-height-normal: 1.7;

            /* Spacing - Increased 30-50% for breathing room */
            --spacing-xs: 0.5rem;
            --spacing-sm: 1rem;
            --spacing-md: 2rem;
            --spacing-lg: 3rem;
            --spacing-xl: 4rem;
            --spacing-2xl: 6rem;
            --spacing-3xl: 8rem;
            --spacing-4xl: 10rem;

            /* Border Radius */
            --radius-sm: 6px;
            --radius-md: 12px;
            --radius-lg: 20px;
            --radius-xl: 28px;

            /* Transitions */
            --transition-fast: 200ms ease;
            --transition-normal: 300ms ease;
            --transition-slow: 400ms ease;

            /* Shadows - Subtle elevation through color */
            --shadow-sm: 0 2px 4px rgba(0, 0, 0, 0.3);
            --shadow-md: 0 6px 12px rgba(0, 0, 0, 0.4);
            --shadow-lg: 0 15px 30px rgba(0, 0, 0, 0.5);
            --shadow-glow: 0 0 30px rgba(139, 92, 246, 0.2);
        }

        /* Reset & Base Styles */
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
            color-scheme: dark;
        }

        body {
            font-family: var(--font-family);
            font-size: var(--font-size-base);
            line-height: var(--line-height-normal);
            color: var(--text-primary);
            background-color: var(--bg-primary);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* Typography */
        h1, h2, h3, h4, h5, h6 {
            font-weight: 700;
            line-height: var(--line-height-relaxed);
            color: var(--text-primary);
            margin-bottom: var(--spacing-sm);
        }

        h1 {
            font-size: clamp(2.5rem, 5vw, 4.5rem);
            letter-spacing: -0.03em;
            line-height: 1.1;
        }

        h2 {
            font-size: clamp(2rem, 4vw, 3.5rem);
            letter-spacing: -0.02em;
            line-height: 1.15;
        }

        h3 {
            font-size: clamp(1.5rem, 3vw, 2rem);
            letter-spacing: -0.01em;
        }

        p {
            color: var(--text-secondary);
            margin-bottom: var(--spacing-md);
            line-height: var(--line-height-relaxed);
            font-size: 1.125rem;
        }

        a {
            color: var(--accent-primary);
            text-decoration: none;
            transition: color var(--transition-fast);
        }

        a:hover {
            color: var(--accent-secondary);
        }

        /* Utility Classes */
        .text-center { text-align: center; }
        .text-gradient {
            background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Container */
        .container {
            width: 100%;
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 var(--spacing-md);
        }

        /* Header/Navigation */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            background-color: rgba(18, 18, 18, 0.95);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-light);
            padding: var(--spacing-sm) 0;
        }

        .nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-primary);
            text-decoration: none;
            letter-spacing: -0.02em;
        }

        .logo span {
            color: var(--accent-primary);
        }

        .nav-links {
            display: flex;
            gap: var(--spacing-lg);
            list-style: none;
        }

        .nav-links a {
            color: var(--text-secondary);
            font-weight: 500;
            transition: color var(--transition-fast);
        }

        .nav-links a:hover {
            color: var(--accent-primary);
        }

        .nav-cta {
            background-color: var(--accent-primary);
            color: white !important;
            padding: var(--spacing-xs) var(--spacing-md);
            border-radius: var(--radius-md);
            font-weight: 600;
            transition: all var(--transition-normal);
        }

        .nav-cta:hover {
            background-color: var(--accent-hover);
            transform: translateY(-2px);
            box-shadow: var(--shadow-glow);
        }

        /* Hero Section - More Spacious */
        .hero {
            padding: var(--spacing-4xl) 0 var(--spacing-3xl);
            text-align: center;
            background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
            min-height: 90vh;
            display: flex;
            align-items: center;
        }

        .hero-content {
            max-width: 900px;
            margin: 0 auto;
        }

        .hero-tagline {
            color: var(--accent-primary);
            font-size: 1.25rem;
            font-weight: 600;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            margin-bottom: var(--spacing-md);
            opacity: 0;
            animation: fadeInUp 0.6s ease forwards;
        }

        .hero h1 {
            margin-bottom: var(--spacing-lg);
            opacity: 0;
            animation: fadeInUp 0.6s ease 0.1s forwards;
        }

        .hero-subtext {
            font-size: 1.375rem;
            color: var(--text-secondary);
            margin-bottom: var(--spacing-xl);
            max-width: 750px;
            margin-left: auto;
            margin-right: auto;
            line-height: 1.85;
            opacity: 0;
            animation: fadeInUp 0.6s ease 0.2s forwards;
        }

        .hero-actions {
            display: flex;
            gap: var(--spacing-md);
            justify-content: center;
            flex-wrap: wrap;
            opacity: 0;
            animation: fadeInUp 0.6s ease 0.3s forwards;
        }

        /* Buttons */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: var(--spacing-xs);
            padding: var(--spacing-sm) var(--spacing-lg);
            border-radius: var(--radius-md);
            font-weight: 600;
            text-decoration: none;
            transition: all var(--transition-normal);
            border: none;
            cursor: pointer;
            font-size: 1.0625rem;
        }

        .btn-primary {
            background-color: var(--accent-primary);
            color: white;
        }

        .btn-primary:hover {
            background-color: var(--accent-hover);
            transform: translateY(-2px);
            box-shadow: var(--shadow-glow);
        }

        .btn-secondary {
            background-color: var(--bg-tertiary);
            color: var(--text-primary);
            border: 1px solid var(--border-medium);
        }

        .btn-secondary:hover {
            background-color: var(--border-medium);
            transform: translateY(-2px);
        }

        /* Sections - More Spacious */
        .section {
            padding: var(--spacing-3xl) 0;
        }

        .section-header {
            text-align: center;
            margin-bottom: var(--spacing-2xl);
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
        }

        .section-title {
            margin-bottom: var(--spacing-md);
        }

        .section-subtitle {
            font-size: 1.25rem;
            line-height: 1.8;
        }

        /* Problem Section */
        .problem-section {
            background-color: var(--bg-secondary);
        }

        .problem-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: var(--spacing-lg);
        }

        .problem-card {
            background-color: var(--bg-tertiary);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-lg);
            padding: var(--spacing-xl);
            transition: all var(--transition-normal);
        }

        .problem-card:hover {
            transform: translateY(-4px);
            border-color: var(--accent-primary);
            box-shadow: var(--shadow-lg);
        }

        .problem-number {
            font-size: 3rem;
            font-weight: 700;
            color: var(--accent-primary);
            opacity: 0.3;
            margin-bottom: var(--spacing-md);
            line-height: 1;
        }

        .problem-card h3 {
            font-size: 1.5rem;
            margin-bottom: var(--spacing-sm);
        }

        /* Approach Section */
        .approach-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
            gap: var(--spacing-lg);
        }

        .approach-card {
            background-color: var(--bg-secondary);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-lg);
            padding: var(--spacing-xl);
            transition: all var(--transition-normal);
        }

        .approach-card:hover {
            transform: translateY(-4px);
            border-color: var(--accent-primary);
            box-shadow: var(--shadow-lg);
        }

        .approach-icon {
            font-size: 3rem;
            margin-bottom: var(--spacing-md);
            line-height: 1;
        }

        .approach-card h3 {
            font-size: 1.375rem;
            margin-bottom: var(--spacing-sm);
        }

        /* Philosophy Section */
        .philosophy-section {
            background-color: var(--bg-secondary);
            padding: var(--spacing-4xl) 0;
        }

        .philosophy-content {
            max-width: 850px;
            margin: 0 auto;
            text-align: center;
        }

        .philosophy-title {
            font-size: clamp(2.5rem, 4vw, 3.5rem);
            margin-bottom: var(--spacing-xl);
            line-height: 1.2;
        }

        .philosophy-text {
            font-size: 1.25rem;
            line-height: 2;
            margin-bottom: var(--spacing-lg);
            color: var(--text-secondary);
        }

        /* Waitlist Section */
        .waitlist-container {
            max-width: 650px;
            margin: 0 auto;
            text-align: center;
        }

        .waitlist-title {
            font-size: clamp(2rem, 4vw, 3rem);
            margin-bottom: var(--spacing-md);
        }

        .waitlist-subtitle {
            font-size: 1.25rem;
            margin-bottom: var(--spacing-xl);
        }

        .waitlist-form {
            display: flex;
            gap: var(--spacing-sm);
            margin-bottom: var(--spacing-md);
            flex-wrap: wrap;
        }

        .waitlist-input {
            flex: 1;
            min-width: 280px;
            padding: var(--spacing-sm) var(--spacing-md);
            font-size: 1.0625rem;
            background-color: var(--bg-tertiary);
            border: 1px solid var(--border-medium);
            border-radius: var(--radius-md);
            color: var(--text-primary);
            transition: all var(--transition-fast);
        }

        .waitlist-input:focus {
            outline: none;
            border-color: var(--accent-primary);
            box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.2);
        }

        .waitlist-input::placeholder {
            color: var(--text-tertiary);
        }

        .waitlist-button {
            padding: var(--spacing-sm) var(--spacing-lg);
            white-space: nowrap;
        }

        .waitlist-note {
            font-size: 1rem;
            color: var(--text-tertiary);
        }

        /* Final CTA Section */
        .final-cta {
            background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-tertiary) 100%);
            padding: var(--spacing-4xl) 0;
            text-align: center;
            border-top: 1px solid var(--border-light);
        }

        .final-cta-content {
            max-width: 700px;
            margin: 0 auto;
        }

        .final-cta-content h2 {
            font-size: clamp(2.5rem, 5vw, 4rem);
            margin-bottom: var(--spacing-md);
        }

        .final-cta-content p {
            font-size: 1.375rem;
            margin-bottom: var(--spacing-xl);
        }

        /* Footer */
        .footer {
            background-color: var(--bg-secondary);
            padding: var(--spacing-2xl) 0 var(--spacing-lg);
            border-top: 1px solid var(--border-light);
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr;
            gap: var(--spacing-xl);
            margin-bottom: var(--spacing-xl);
        }

        .footer-brand h3 {
            margin-bottom: var(--spacing-sm);
        }

        .footer-brand p {
            color: var(--text-tertiary);
            font-size: 0.9375rem;
        }

        .footer-column h4 {
            font-size: 0.875rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-tertiary);
            margin-bottom: var(--spacing-md);
        }

        .footer-column ul {
            list-style: none;
        }

        .footer-column li {
            margin-bottom: var(--spacing-xs);
        }

        .footer-column a {
            color: var(--text-secondary);
            font-size: 0.9375rem;
        }

        .footer-column a:hover {
            color: var(--accent-primary);
        }

        .footer-bottom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: var(--spacing-lg);
            border-top: 1px solid var(--border-light);
            color: var(--text-tertiary);
            font-size: 0.9375rem;
        }

        /* Animations */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Mobile Navigation */
        @media (max-width: 768px) {
            .nav-links {
                display: none;
            }

            .hero {
                padding: var(--spacing-3xl) 0 var(--spacing-2xl);
                min-height: auto;
            }

            .hero h1 {
                font-size: 2.25rem;
            }

            .hero-subtext {
                font-size: 1.125rem;
            }

            .hero-actions {
                flex-direction: column;
                align-items: stretch;
            }

            .problem-grid,
            .approach-grid {
                grid-template-columns: 1fr;
            }

            .waitlist-form {
                flex-direction: column;
            }

            .waitlist-input,
            .waitlist-button {
                width: 100%;
            }

            .footer-grid {
                grid-template-columns: 1fr;
                gap: var(--spacing-lg);
            }

            .footer-bottom {
                flex-direction: column;
                gap: var(--spacing-sm);
                text-align: center;
            }

            /* More spacing on mobile */
            .section {
                padding: var(--spacing-2xl) 0;
            }

            .problem-card,
            .approach-card {
                padding: var(--spacing-lg);
            }
        }
    </style>
</head>
<body>
    <header class="header">
        <div class="container">
            <nav class="nav">
                <a href="/" class="logo">Beneden<span>.</span></a>
                <ul class="nav-links">
                    <li><a href="/">Home</a></li>
                    <li><a href="/about/">About</a></li>
                    <li><a href="/contact/">Contact</a></li>
                    <li><a href="#waitlist" class="nav-cta">Join Waitlist</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main>
        {{ content | safe }}
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <h3>Beneden.</h3>
                    <p>A new world awaits. Social media that will never monetize attention.</p>
                </div>
                <div class="footer-column">
                    <h4>Product</h4>
                    <ul>
                        <li><a href="#how-it-works">How It Works</a></li>
                        <li><a href="#waitlist">Join Waitlist</a></li>
                        <li><a href="/contact/">Contact</a></li>
                    </ul>
                </div>
                <div class="footer-column">
                    <h4>Company</h4>
                    <ul>
                        <li><a href="/about/">About</a></li>
                        <li><a href="#">Mission</a></li>
                        <li><a href="#">Blog</a></li>
                    </ul>
                </div>
                <div class="footer-column">
                    <h4>Connect</h4>
                    <ul>
                        <li><a href="#">Twitter</a></li>
                        <li><a href="#">LinkedIn</a></li>
                        <li><a href="#">Email</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2025 Beneden. All rights reserved.</p>
                <p>hello@beneden.gg</p>
            </div>
        </div>
    </footer>
</body>
</html>
